{
  "name": "@summation/summation-skill",
  "version": "0.1.0",
  "description": "Install the Summation agent skill for Codex and Claude Code.",
  "license": "UNLICENSED",
  "private": false,
  "bin": {
    "summation-skill": "bin/summation-skill.js"
  },
